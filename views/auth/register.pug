extends ../layouts/master

block web-content
  .row.justify-content-center
    .col-md-6
      h1.h3.mb-3.text-center Daftar Akun

      if errors && errors.length
        .alert.alert-danger
          ul.mb-0
            each pesan in errors
              li= pesan

      .card
        .card-body
          form(method="post", action="/register")
            .mb-3
              label.form-label(for="name") Nama
              input.form-control#name(type="text", name="name", value=old.name || "", required)
            .mb-3
              label.form-label(for="email") Email
              input.form-control#email(type="email", name="email", value=old.email || "", required)
            .mb-3
              label.form-label(for="password") Password
              input.form-control#password(type="password", name="password", required)
              .form-text Minimal 8 karakter.
            .mb-3
              label.form-label(for="password_confirmation") Konfirmasi Password
              input.form-control#password_confirmation(type="password", name="password_confirmation", required)
            .d-grid
              button.btn.btn-success(type="submit") Daftar
          p.text-center.mt-3.mb-0
            | Sudah punya akun? 
            a(href="/login") Login di sini