extends ../layouts/auth

block web-content
  .card
    .card-body.login-card-body
      p.login-box-msg Masuk untuk memulai sesi

      if errors && errors.length
        .alert.alert-danger
          ul.mb-0.pl-3
            each pesan in errors
              li= pesan

      form(method="post", action="/login")
        .input-group.mb-3
          input.form-control(type="email", name="email", placeholder="Email", value=old.email || "", required)
          .input-group-append
            .input-group-text
              span.fas.fa-envelope
        .input-group.mb-3
          input.form-control(type="password", name="password", placeholder="Password", required)
          .input-group-append
            .input-group-text
              span.fas.fa-lock
        .row
          .col-12
            button.btn.btn-primary.btn-block(type="submit") Masuk