doctype html
html(lang="id")
  head
    meta(charset="utf-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title MiniPustaka - #{title}
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css")
    link(rel="stylesheet", href="/css/style.css")
    block web-css
  body
    nav.navbar.navbar-expand-lg.navbar-dark.bg-dark
      .container
        a.navbar-brand(href="/") MiniPustaka
        .navbar-nav.me-auto
          if currentUser
            a.nav-link(href="/") Dashboard
            a.nav-link(href="/books") Buku
        .navbar-nav
          if currentUser
            span.navbar-text.text-light.me-3 Halo, #{currentUser.name}
            form.d-inline(method="post", action="/logout")
              button.btn.btn-sm.btn-outline-light(type="submit") Logout
          else
            a.nav-link(href="/login") Login
            a.nav-link(href="/register") Daftar

    .container.py-4
      //- Pesan flash sekali tampil
      if success && success.length
        .alert.alert-success= success[0]
      if error && error.length
        .alert.alert-danger= error[0]

      block web-content

script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js")
block web-js